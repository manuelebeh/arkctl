{
  "name": "{{project_name}}",
  "type": "project",
  "description": "Ark Laravel nwidart modules scaffold",
  "require": {
    "php": "^8.2",
    "nwidart/laravel-modules": "^12.0"
  },
  "config": {
    "allow-plugins": {
      "wikimedia/composer-merge-plugin": true
    }
  },
  "extra": {
    "merge-plugin": {
      "include": [
        "Modules/*/composer.json"
      ]
    }
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Modules\\": "Modules/"
    }
  }
}
